# EUDAMED Scraper — Environment Variables
# Copy this file to .env and fill in values before running.
# .env is git-ignored; .env.example is committed.

# Base URL of the EUDAMED portal (no trailing slash)
BASE_URL=https://ec.europa.eu/tools/eudamed

# ISO 3166-1 alpha-2 country code to scrape (e.g. US, DE, FR, GB)
COUNTRY_CODE=US

# Number of records per list page (max supported by EUDAMED API is 50)
PAGE_SIZE=50

# Output file paths — leave commented to use auto-generated defaults
# Default: ./output/eudamed_export_<COUNTRY_CODE>.xlsx
# OUTPUT_FILE=./output/eudamed_export.xlsx

# Default: ./output/eudamed_export_<COUNTRY_CODE>.csv
# CSV_FILE=./output/eudamed_export.csv

# Internal staging and checkpoint files (used for crash recovery)
STAGING_FILE=./output/staging.jsonl
CHECKPOINT_FILE=./output/progress.json

# Run Puppeteer in headless mode (true = headless, false = visible browser window)
HEADLESS=true

# Polite delay between detail page requests (milliseconds)
MIN_DELAY_MS=1000
MAX_DELAY_MS=3000

# Maximum number of retry attempts per page or detail request
MAX_RETRIES=3

# How often to save a checkpoint (every N records)
CHECKPOINT_INTERVAL=50

# Path for the error/warning log file
LOG_FILE=./logs/errors.log
